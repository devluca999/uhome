# Copy to .env.test and fill with values from `supabase status`
# Used by Playwright and test helpers (merged with `.env` / `.env.local` — see playwright.config.ts)
#
# If `npm run test:smoke` fails with "fetch failed" on signup:
# - Local: run `npx supabase start` and use http://127.0.0.1:54321 (prefer 127.0.0.1 over localhost on Windows)
# - Or point VITE_SUPABASE_URL at staging; keep SUPABASE_ENV non-production

SUPABASE_ENV=local
VITE_ENVIRONMENT=development
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=<from supabase status>
SUPABASE_SERVICE_KEY=<from supabase status>

# Or use TEST_SUPABASE_SERVICE_KEY if preferred
# TEST_SUPABASE_SERVICE_KEY=<from supabase status>
