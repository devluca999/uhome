# Local Edge Function secrets — copy to `.env` in this folder (gitignored).
# Loaded automatically when you run `supabase start` (see Supabase Functions secrets docs).
#
#   copy supabase\functions\.env.example supabase\functions\.env
# Then paste your Stripe TEST keys and webhook signing secrets.

STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_connect_webhook_signing_secret
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=whsec_your_subscription_webhook_signing_secret
