# =============================================================================
# uhome — environment template
# Copy to `.env.local` (gitignored). Never commit real keys.
#
# Three targets (Supabase + Vite must always agree: URL + anon from the SAME project):
#
#   1) LOCAL — Supabase CLI (Docker). Keys from `npx supabase status` (API URL/port).
#   2) STAGING — Cloud project “uhome staging” + Vercel Preview from `develop`.
#   3) PRODUCTION — Cloud project “uhome-app” + Vercel Production from `main`.
#
# Details: docs/environment-mapping.md · Full var list: docs/environment-variables.md
# =============================================================================

# -----------------------------------------------------------------------------
# App tier (required — parsed by src/config/environment.ts)
#   development — local Vite + local OR remote Supabase (aliases: dev, local)
#   staging       — Preview / staging hosts
#   production    — production hosts only
# Legacy fallback: VITE_SUPABASE_ENV (prefer VITE_ENVIRONMENT)
# -----------------------------------------------------------------------------
VITE_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Supabase — pair these from ONE project only
# Local default API: http://127.0.0.1:54321 (run `npx supabase status` if your port differs)
# Staging: uhome staging project in Dashboard
# Production: uhome-app project (set on Vercel Production, not usually in .env.local)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Scripts / seeds / tests (Node only; never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Node-side label for guards (local | staging | production) — align with VITE_ENVIRONMENT
SUPABASE_ENV=local
# Optional mirror for older checks
VITE_SUPABASE_ENV=local

# -----------------------------------------------------------------------------
# Vercel / CI hosting hint (optional; VERCEL_ENV is injected on Vercel)
# preview = Preview deploys; production = Production deploy
# -----------------------------------------------------------------------------
# VITE_HOSTING_ENV=preview

# Production build safety: staging Supabase project ref only (subdomain of .supabase.co)
# Set on Vercel Production so the client can refuse a miswired production URL.
# VITE_STAGING_SUPABASE_PROJECT_REF=your_staging_ref_only

# -----------------------------------------------------------------------------
# Supabase CLI helpers (optional — for scripts/db-push.ts etc.)
# -----------------------------------------------------------------------------
SUPABASE_STAGING_PROJECT_REF=
SUPABASE_PRODUCTION_PROJECT_REF=

# -----------------------------------------------------------------------------
# Guardrails for destructive scripts
# CONFIRM_PRODUCTION_DB_PUSH=yes   # required for npm run db:migrate → production
# CONFIRM_STAGING_RESEED=yes      # required for npm run seed:demo → remote (non-local URL)

# -----------------------------------------------------------------------------
# Optional: cross-project verification scripts
# SUPABASE_CLOUD_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY_CLOUD=your-service-role-key

# Sentry (client)
VITE_SENTRY_DSN=

# Stripe — client publishable (Vite). Secret keys live in supabase/functions secrets, not here.
VITE_STRIPE_PUBLISHABLE_KEY=

# Dev-only UI helpers (safe to true locally; use false for staging-like behaviour)
VITE_TENANT_DEV_MODE_ENABLED=true
VITE_LANDLORD_DEV_MODE_ENABLED=true
