# Frontend (Vite embeds these at build time)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# development | staging | production (aliases: dev, local, prod)
VITE_ENVIRONMENT=development

# Server-side / Edge Functions (never expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase CLI — project refs (subdomain of https://<ref>.supabase.co). Used by scripts/db-push.ts
# uhome-staging / uhome-app in the dashboard map to these refs.
SUPABASE_STAGING_PROJECT_REF=
SUPABASE_PRODUCTION_PROJECT_REF=

# Required to push migrations to the production project when linked (npm run db:migrate)
# CONFIRM_PRODUCTION_DB_PUSH=yes

# Required to run npm run seed:demo against any non-local Supabase URL (e.g. staging)
# CONFIRM_STAGING_RESEED=yes

# Optional: for verify:cloud-parity (cloud project credentials)
# SUPABASE_CLOUD_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY_CLOUD=your-service-role-key

# Stripe (Edge Functions: create-connect-account, create-payment-intent, stripe-connect-webhook)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Postal (Edge Functions: send-email, email-webhook)
POSTAL_WEBHOOK_SECRET=your-postal-webhook-secret
POSTAL_SMTP_HOST=postal.yourdomain.com
POSTAL_SMTP_USER=...
POSTAL_SMTP_PASS=...
POSTAL_SMTP_PORT=587
POSTAL_FROM_EMAIL=noreply@uhome.app

# Web Push (Edge Function: send-push)
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
